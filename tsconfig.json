{
  "compilerOptions": {
    "target":           "ES2022",
    "lib":              ["dom", "dom.iterable", "ES2022"],
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "jsx":              "preserve",
    "allowJs":          false,
    "strict":           true,
    "noEmit":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "isolatedModules":  true,
    "resolveJsonModule": true,
    "incremental":      true,
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
